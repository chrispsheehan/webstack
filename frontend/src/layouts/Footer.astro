---
const { baseDomain } = Astro.props;
const year = new Date().getFullYear();
const siteVersion = (import.meta.env.PUBLIC_SITE_VERSION || "1.0.0").slice(
  0,
  8,
);
---

<style>
  footer {
    padding: 8px 16px;
    background: var(--color-background-dark);
    color: var(--color-heading);
    font-size: 14px;
  }

  .footer-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    line-height: 1.3;
  }

  .footer-version {
    font-size: 14px;
    margin: 0;
  }

  @media (max-width: 700px) {
    .footer-container {
      justify-content: center;
      text-align: center;
      gap: 4px 12px;
    }
  }
</style>

<footer>
  <div class="footer-container">
    <p>&copy; {year} {baseDomain}</p>
    <p class="footer-version">{siteVersion}</p>
  </div>
</footer>
