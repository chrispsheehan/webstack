---
import CostExplorer from "../components/CostExplorer";
import Visits from "../components/Visits";

const { githubRepo } = Astro.props;
---

<section id="this-site">
  <h2>This Site</h2>
  <p>
    Astro-powered and deployed with Terragrunt and GitHub Actions. A fast,
    serverless site that's inexpensive to run.
  </p>
  <div class="container">
    <div class="dashboard-wrapper">
      <div class="dashboard-row">
        <div class="dashboard-card github-card">
          <a
            href={`https://github.com/${githubRepo}`}
            target="_blank"
            rel="noopener noreferrer"
            class="github-card-link"
          >
            <div class="github-card-content">
              <img
                class="pipeline-badge"
                src={`https://github.com/${githubRepo}/actions/workflows/release_prod.yml/badge.svg`}
                alt="Webstack Workflow Status"
              />
              <div class="github-repo-button">
                <img src="/assets/social/github.png" alt="GitHub" />
                <span>Source Code</span>
              </div>
            </div>
          </a>
        </div>
        <Visits client:load />
        <CostExplorer client:load />
      </div>
    </div>
  </div>
</section>

<style is:global>
  .container {
    width: 100%;
    padding: 0;
    box-sizing: border-box;
  }

  .dashboard-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    flex: 1 1 0;
    min-width: 0;
  }

  .dashboard-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    width: 100%;
    align-items: stretch;
  }

  .dashboard-card {
    background: var(--color-surface);
    border-radius: 1rem;
    padding: 1.5rem;
    max-width: 400px;
    min-width: 280px;
    min-height: 180px;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    position: relative;
    text-align: left;
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
    border: 1px solid var(--color-border-soft);
  }

  .dashboard-card:hover {
    background: var(--color-surface-2);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .pipeline-badge {
    height: 28px;
    object-fit: contain;
    margin: 0;
  }

  .github-repo-button img {
    width: 28px;
    height: 28px;
    object-fit: contain;
    display: inline-block;
  }

  .github-card {
    justify-content: center;
    max-width: none;
    min-width: 0;
    align-items: center;
    text-align: center;
  }

  .github-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    width: 100%;
    height: 100%;
  }

  .dashboard-card--data {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .github-card-content {
    border: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    justify-content: center;
  }

  .github-repo-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    border-radius: 8px;
    background: var(--color-background-dark);
    color: var(--color-text);
    font-weight: 600;
    white-space: nowrap;
    font-size: 1rem;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  .github-card-link:hover .github-repo-button {
    background: var(--color-surface-2);
    transform: translateY(-1px);
  }

  .dashboard-card h3 {
    margin: 0 0 1rem;
    font-size: 1.3rem;
    color: var(--color-text);
  }

  .dashboard-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  .dashboard-card li {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: baseline;
    gap: 1rem;
    width: 100%;
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }

  .dashboard-card strong {
    font-weight: 600;
    color: var(--color-heading);
    min-width: 0;
  }

  .metric-value {
    font-weight: 700;
    color: var(--color-hover);
    font-variant-numeric: tabular-nums;
    justify-self: end;
    text-align: right;
    white-space: nowrap;
  }

  .dashboard-card small {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .github-card-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 1rem;
  }

  .dashboard-card:focus-within {
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-border-strong);
  }

  @media (max-width: 1000px) {
    .dashboard-wrapper {
      width: 100%;
    }

    .dashboard-row {
      grid-template-columns: 1fr;
    }

    .dashboard-card,
    .github-card {
      margin-left: auto;
      margin-right: auto;
      width: 100%;
      min-width: unset;
      max-width: unset;
    }

  }
</style>
