---
const { baseDomain, githubRepo } = Astro.props;
const githubOwner = githubRepo.split("/")[0];
---

<header>
  <nav>
    <div class="nav-left">
      <span class="logo">{baseDomain}</span>
    </div>

    <!-- Top-right nav buttons (desktop) -->
    <div class="nav-links" id="nav-links">
      <a href="#about-me" class="button hide-on-desktop">About Me</a>
      <a href="#certifications" class="button hide-on-desktop">Certifications</a
      >
      <a href="#this-site" class="button hide-on-desktop">This Site</a>
      <a
        href={`https://github.com/${githubOwner}`}
        target="_blank"
        rel="noopener noreferrer"
        class="button github-text-icon-button"
      >
        <span>GitHub</span>
        <img src="/assets/social/github.png" alt="GitHub" />
      </a>
      <a
        href="https://www.linkedin.com/in/chrispsheehan"
        target="_blank"
        rel="noopener noreferrer"
        class="button"
      >
        <span>LinkedIn</span>
        <img
          src="/assets/social/linkedin.png"
          alt="LinkedIn"
          class="nav-social-icon"
        />
      </a>
      <a
        href="https://registry.terraform.io/namespaces/chrispsheehan"
        target="_blank"
        rel="noopener noreferrer"
        class="button"
      >
        <span>Terraform</span>
        <img
          src="/assets/social/terraform.png"
          alt="Terraform"
          class="nav-social-icon"
        />
      </a>
    </div>

    <!-- Mobile fullscreen menu -->
    <div class="mobile-overlay" id="mobile-overlay">
      <a href="#about-me" class="overlay-button" onclick="hideMenu()"
        >About Me</a
      >
      <a href="#certifications" class="overlay-button" onclick="hideMenu()"
        >Certifications</a
      >
      <a href="#this-site" class="overlay-button" onclick="hideMenu()"
        >This Site</a
      >
      <a
        href={`https://github.com/${githubRepo}`}
        target="_blank"
        rel="noopener noreferrer"
        class="overlay-icon-button"
        onclick="hideMenu()"
      >
        <img src="/assets/social/github.png" alt="GitHub" />
      </a>
      <a
        href="https://www.linkedin.com/in/chrispsheehan"
        target="_blank"
        rel="noopener noreferrer"
        class="overlay-icon-button"
        onclick="hideMenu()"
      >
        <img src="/assets/social/linkedin.png" alt="LinkedIn" />
      </a>
      <a
        href="https://registry.terraform.io/namespaces/chrispsheehan"
        target="_blank"
        rel="noopener noreferrer"
        class="overlay-icon-button"
        onclick="hideMenu()"
      >
        <img src="/assets/social/terraform.png" alt="Terraform" />
      </a>
    </div>

    <!-- Burger icon -->
    <button
      class="burger"
      id="burger"
      aria-label="Toggle menu"
      onclick="toggleMenu()"></button>
  </nav>

  <script type="module">
    import "/scripts/mobileMenu.js";
  </script>

  <style>
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      box-sizing: border-box;
      padding: 20px 32px;
      background: var(--color-background-dark);
      position: relative;
      z-index: 100;
    }

    .nav-left .logo {
      color: var(--color-heading);
      font-weight: bold;
      font-size: 1.25rem;
    }

    .nav-links {
      display: flex;
      gap: 12px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      color: var(--color-text);
      background: var(--color-surface);
      text-decoration: none;
      border-radius: 6px;
      font-weight: bold;
      border: 1px solid var(--color-border-strong);
      cursor: pointer;
      min-height: 44px;
      transition:
        background 0.2s ease,
        color 0.2s ease,
        transform 0.2s ease;
    }

    .button:hover {
      background: var(--color-surface-2);
      color: var(--color-heading);
      transform: translateY(-1px);
    }

    .github-text-icon-button img {
      width: 24px;
      height: 24px;
    }

    .nav-social-icon {
      width: 24px;
      height: 24px;
    }

    .burger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      position: absolute;
      right: 32px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 1100;
      font-size: 35px;
      color: var(--color-heading);
    }

    .burger::before {
      content: "☰";
    }

    .burger.show::before {
      content: "✕";
    }

    .mobile-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1000;
      background: var(--color-background-dark);
      padding: 16px;
      box-sizing: border-box;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 24px;
    }

    body.no-scroll,
    html.no-scroll {
      overflow: hidden !important;
      height: 100%;
      touch-action: none;
      overscroll-behavior: none;
    }

    .mobile-overlay.show {
      display: flex;
    }

    .overlay-button {
      padding: 16px 32px;
      font-size: 1.5rem;
      background: var(--color-surface);
      color: var(--color-text);
      text-decoration: none;
      border-radius: 8px;
      font-weight: bold;
      border: 1px solid var(--color-border-strong);
    }

    .overlay-button:hover {
      background: var(--color-surface-2);
      color: var(--color-heading);
    }

    .overlay-icon-button {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100px;
      width: 100px;
      border-radius: 8px;
      background: var(--color-surface);
      border: 1px solid var(--color-border-strong);
      transition:
        background 0.2s ease,
        transform 0.2s ease;
    }

    .overlay-icon-button:hover {
      background: var(--color-surface-2);
      transform: translateY(-1px);
    }

    .overlay-icon-button img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 6px;
      box-sizing: border-box;
    }

    @media (max-width: 1000px) {
      .burger {
        display: block;
      }

      .nav-links {
        display: none;
      }

      nav {
        padding: 16px;
      }
    }

    @media (min-width: 1000px) {
      .hide-on-desktop {
        display: none !important;
      }
    }

    .button:focus-visible,
    .overlay-button:focus-visible,
    .overlay-icon-button:focus-visible,
    .burger:focus-visible {
      outline: 2px solid var(--color-hover);
      outline-offset: 2px;
    }
  </style>
</header>
