---
import Certifications from "../components/Certifications";
---

<style is:global>
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    justify-content: center;
    gap: 2rem;
  }

  .cert-grid > a {
    display: block;
    max-width: 220px;
    width: auto;
    text-align: center;
    margin: 0 auto;
    justify-self: center;
    padding: 0.5rem;
    border-radius: 1rem;
    background: var(--color-cert-card);
    border: 1px solid var(--color-cert-card-border);
    -webkit-tap-highlight-color: transparent;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .cert-grid > a.cert-card--embed {
    padding: 0;
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .cert-grid > a.cert-card--embed:hover {
    background: transparent;
    box-shadow: none;
  }

  .cert-grid > a:hover .cert-img-wrapper {
    transform: translateY(-2px);
  }

  .cert-grid > a:hover .cert-embed-wrapper {
    transform: translateY(-2px);
  }

  .cert-grid > a:hover {
    background: var(--color-cert-card-hover);
    box-shadow: var(--shadow-cert-hover);
  }

  .cert-grid > a:focus-visible {
    outline: 2px solid var(--color-hover);
    outline-offset: 2px;
  }

  .cert-img-wrapper {
    width: 150px;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    background: transparent;
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .cert-embed-wrapper {
    width: 180px;
    min-height: 260px;
    margin: 0 auto;
    border-radius: 0.75rem;
    background: var(--color-cert-embed-bg);
    overflow: hidden;
    transition: transform 0.2s ease;
  }

  .cert-embed-wrapper iframe {
    border: 0;
    display: block;
    margin: 0 auto;
  }

  .cert-img-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (max-width: 1000px) {
    .cert-grid {
      grid-template-columns: repeat(auto-fit, minmax(180px, 180px));
      gap: 1rem;
      justify-content: center;
    }

    .cert-grid > a {
      max-width: 220px;
    }
  }
</style>

<section id="certifications">
  <h2>Certifications</h2>
  <h3>
    Certifications that back up the platform, cloud, and delivery work I do in
    practice.
  </h3>
  <p>
    The focus here is AWS, Terraform, and DevOps capability rather than
    collecting badges for their own sake.
  </p>
  <Certifications client:load />
</section>
