---
import Certifications from "../components/Certifications";
---

<style is:global>
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    justify-content: center;
    gap: 2rem;
  }

  .cert-grid > a {
    display: block;
    max-width: 220px;
    width: 100%;
    text-align: center;
    margin: 0 auto;
    padding: 0.5rem;
    border-radius: 1rem;
    background: var(--color-heading);
    transition:
      transform 0.2s ease,
      background 0.2s ease;
  }

  .cert-grid > a:hover .cert-img-wrapper {
    transform: translateY(-2px) scale(1.02);
  }

  .cert-grid > a:hover .cert-embed-wrapper {
    transform: translateY(-2px) scale(1.02);
  }

  .cert-grid > a:hover {
    background: var(--color-link);
  }

  .cert-grid > a:focus,
  .cert-grid > a:active {
    outline: none;
    box-shadow: none;
    background: none;
  }

  .cert-img-wrapper {
    width: 150px;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    background: transparent;
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .cert-embed-wrapper {
    width: 150px;
    min-height: 270px;
    margin: 0 auto;
    border-radius: 1rem;
    background: transparent;
    transition: transform 0.2s ease;
  }

  .cert-img-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (max-width: 1000px) {
    .cert-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      max-width: 960px;
      width: 100%;
      grid-template-columns: repeat(auto-fit, minmax(50px, 1fr));
    }
  }
</style>

<section id="certifications">
  <h2>Certifications</h2>
  <h3>
    A collection of certifications I've earned in cloud, DevOps, and software
    engineering.
  </h3>
  <p>
    Each reflects a step in my learning journey and the practical experience
    gained along the way.
  </p>
  <Certifications client:load />
</section>
